---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.tsx';
import TrilogyContainer from '../components/TrilogyContainer.tsx';
import HeroSection from '../components/HeroSection.tsx';
import TechStackSection from '../components/TechStackSection.tsx';
import ProjectTrilogySection from '../components/ProjectTrilogySection.tsx';
import PeecemakerSection from '../components/PeecemakerSection.tsx';
import ForTheTeamSection from '../components/ForTheTeamSection.tsx';
import UfcSection from '../components/UfcSection.tsx';
import Footer from '../components/Footer.tsx';
---
<Layout title="NX280 | Trilogy Portfolio">
  <Header client:load />
  
  <TrilogyContainer client:load>
    <HeroSection client:load />
    <TechStackSection client:visible />
    <ProjectTrilogySection client:visible />
    <PeecemakerSection client:visible />
    <ForTheTeamSection client:visible />
    <UfcSection client:visible />
    <Footer client:visible />
  </TrilogyContainer>
</Layout>
